<% pageClass = "page-listings"; %>
<% pageTitle = "Listings"; %>
<% layout("layouts/boilerplate") %>

<section class="page-hero">
  <div class="container">
    <div class="page-hero-panel fade-up">
      <div class="section-kicker bg-white text-dark">
        <i class="fa-solid fa-compass"></i>
        Browse stays
      </div>
      <h1 class="section-title text-white mb-2">
        <% if (search) { %>
          Results for "<%= search %>"
        <% } else { %>
          Discover places that feel worth staying in
        <% } %>
      </h1>
      <p class="mb-0 text-white-50">
        <% if (search) { %>
          <%= allListings.length %> listing<%= allListings.length !== 1 ? "s" : "" %> matched your search.
        <% } else { %>
          Clearer cards, stronger hierarchy, and a less noisy browsing experience.
        <% } %>
      </p>
    </div>
  </div>
</section>

<section class="page-section">
  <div class="container">
    <div class="listings-layout">
      <aside class="filters-panel shell-card fade-up">
        <form action="/listings" method="GET" class="filter-stack" data-listing-filters>
          <div class="d-flex justify-content-between align-items-center">
            <h2 class="h5 mb-0">Search filters</h2>
            <button class="btn btn-sm btn-outline-secondary" type="reset" data-clear-filters>Reset</button>
          </div>

          <div class="filter-group">
            <label for="listingSearch" class="filter-label">Keyword</label>
            <input id="listingSearch" type="text" name="search" class="form-control" placeholder="City, country, or keyword" value="<%= search || '' %>">
          </div>

          <div class="filter-group">
            <span class="filter-label">Nightly budget</span>
            <div class="price-range-row">
              <input type="number" class="form-control" name="minPrice" placeholder="Min &#8377;" data-price-min>
              <input type="number" class="form-control" name="maxPrice" placeholder="Max &#8377;" data-price-max>
            </div>
          </div>

          <div class="filter-group">
            <span class="filter-label">Property type</span>
            <label class="filter-check"><input type="checkbox" disabled> Apartment</label>
            <label class="filter-check"><input type="checkbox" disabled> House</label>
            <label class="filter-check"><input type="checkbox" disabled> Villa</label>
            <small class="text-soft">These controls are staged for backend filter wiring next.</small>
          </div>

          <div class="filter-group">
            <span class="filter-label">Popular amenities</span>
            <label class="filter-check"><input type="checkbox" disabled> WiFi</label>
            <label class="filter-check"><input type="checkbox" disabled> Kitchen</label>
            <label class="filter-check"><input type="checkbox" disabled> Air conditioning</label>
            <label class="filter-check"><input type="checkbox" disabled> Pool</label>
          </div>

          <button class="btn btn-primary w-100" type="submit">
            <i class="fa-solid fa-magnifying-glass me-2"></i>Search listings
          </button>
        </form>
      </aside>

      <div>
        <div class="results-toolbar fade-up">
          <div>
            <h2 class="h4 mb-1">Available stays</h2>
            <p class="text-soft mb-0">Designed to make comparison feel simpler.</p>
          </div>
          <% if (currUser) { %>
            <a href="/listings/new" class="btn btn-primary">
              <i class="fa-solid fa-plus me-2"></i>Add listing
            </a>
          <% } %>
        </div>

        <% if (allListings.length === 0) { %>
          <div class="shell-card empty-state fade-up">
            <div class="empty-state-icon">
              <i class="fa-solid fa-magnifying-glass"></i>
            </div>
            <h3 class="h4">No listings matched that search.</h3>
            <p class="text-soft mb-4">Try a broader term, or return to the full collection and browse from there.</p>
            <div class="d-flex justify-content-center gap-2 flex-wrap">
              <a href="/listings" class="btn btn-primary">See all listings</a>
              <% if (currUser) { %>
                <a href="/listings/new" class="btn btn-outline-primary">Create a listing</a>
              <% } %>
            </div>
          </div>
        <% } else { %>
          <div class="listing-grid">
            <% for (let listing of allListings) { %>
              <article class="listing-card fade-up">
                <div class="listing-media">
                  <img src="<%= listing.image && listing.image.url ? listing.image.url : 'https://via.placeholder.com/800x600?text=No+Image' %>" alt="<%= listing.title %>" loading="lazy" onerror="this.onerror=null; this.src='https://via.placeholder.com/800x600?text=Image+Unavailable';">
                  <button class="wishlist-btn" data-listing-id="<%= listing._id %>" aria-label="Toggle wishlist">
                    <i class="fa-regular fa-heart"></i>
                  </button>
                  <div class="listing-badge">
                    <i class="fa-solid fa-location-dot"></i>
                    <span><%= listing.location %></span>
                  </div>
                </div>
                <div class="listing-card-body">
                  <div class="listing-topline mb-2">
                    <a href="/listings/<%= listing._id %>">
                      <h3 class="h5 mb-0"><%= listing.title %></h3>
                    </a>
                    <span class="price-tag"><span class="currency">&#8377;</span><%= listing.price.toLocaleString("en-IN") %></span>
                  </div>
                  <div class="listing-meta-row mb-3">
                    <span><i class="fa-solid fa-earth-asia me-1"></i><%= listing.country %></span>
                    <span><i class="fa-solid fa-receipt me-1"></i>Per night</span>
                  </div>
                  <p class="listing-description mb-3"><%= listing.description.length > 110 ? `${listing.description.substring(0, 110)}...` : listing.description %></p>
                  <div class="listing-footer-row">
                    <span class="text-soft"><i class="fa-solid fa-circle-check me-1 text-success"></i>Trusted host flow</span>
                    <a href="/listings/<%= listing._id %>" class="btn btn-outline-primary btn-sm">View details</a>
                  </div>
                </div>
              </article>
            <% } %>
          </div>
        <% } %>
      </div>
    </div>
  </div>
</section>
