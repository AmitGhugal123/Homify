<% pageClass = "page-form"; %>
<% pageTitle = "New Listing"; %>
<% layout("layouts/boilerplate") %>

<section class="page-hero">
  <div class="container form-shell">
    <div class="page-hero-panel fade-up">
      <div class="section-kicker bg-white text-dark">Host with clarity</div>
      <h1 class="section-title text-white mb-2">List your property with a cleaner, more guided form.</h1>
      <p class="mb-0 text-white-50">The goal is to make creating a listing feel professional instead of overwhelming.</p>
    </div>
  </div>
</section>

<section class="page-section pt-0">
  <div class="container form-shell">
    <article class="form-card shell-card fade-up">
      <form method="POST" action="/listings" enctype="multipart/form-data" class="form-grid needs-validation" novalidate>
        <div>
          <label for="title" class="form-label">Property title</label>
          <input name="listing[title]" id="title" type="text" placeholder="Cozy apartment in the city center" class="form-control" required>
          <div class="invalid-feedback">Please provide a listing title.</div>
        </div>

        <div>
          <label for="description" class="form-label">Description</label>
          <textarea name="listing[description]" id="description" rows="5" placeholder="Describe the stay, the neighborhood, and what makes it memorable." class="form-control" required></textarea>
          <div class="invalid-feedback">Please provide a description.</div>
        </div>

        <div>
          <label for="image" class="form-label">Property image</label>
          <input name="image" id="image" type="file" class="form-control" accept="image/*">
        </div>

        <div>
          <label for="price" class="form-label">Price per night</label>
          <div class="input-group">
            <span class="input-group-text">&#8377;</span>
            <input name="listing[price]" id="price" type="number" placeholder="2500" class="form-control" min="0" required>
          </div>
          <div class="invalid-feedback">Please provide a valid price.</div>
        </div>

        <div class="form-grid-2">
          <div>
            <label for="location" class="form-label">Location</label>
            <input name="listing[location]" id="location" type="text" placeholder="Jaipur" class="form-control" required>
            <div class="invalid-feedback">Please provide a location.</div>
          </div>
          <div>
            <label for="country" class="form-label">Country</label>
            <input name="listing[country]" id="country" type="text" placeholder="India" class="form-control" required>
            <div class="invalid-feedback">Please provide a country.</div>
          </div>
        </div>

        <div class="d-flex gap-2 flex-wrap pt-2">
          <button type="submit" class="btn btn-primary px-4">Publish listing</button>
          <a href="/listings" class="btn btn-outline-secondary px-4">Cancel</a>
        </div>
      </form>
    </article>
  </div>
</section>
