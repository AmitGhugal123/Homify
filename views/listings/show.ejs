<% pageClass = "page-show"; %>
<% pageTitle = listing.title; %>
<% layout("layouts/boilerplate") %>

<section class="page-section">
  <div class="container">
    <div class="detail-hero-grid">
      <div class="detail-image-wrap fade-up">
        <img src="<%= listing.image && listing.image.url ? listing.image.url : 'https://via.placeholder.com/1200x800?text=No+Image' %>" alt="<%= listing.title %>" loading="lazy" onerror="this.onerror=null; this.src='https://via.placeholder.com/1200x800?text=Image+Unavailable';">
      </div>

      <aside class="detail-sidebar">
        <div class="detail-card fade-up">
          <div class="section-kicker mb-3">
            <i class="fa-solid fa-house"></i>
            Property overview
          </div>
          <h1 class="section-title mb-2" style="font-size: clamp(2.2rem, 4vw, 3.4rem);"><%= listing.title %></h1>
          <div class="detail-meta-grid mb-3">
            <span><i class="fa-solid fa-location-dot me-2 text-danger"></i><%= listing.location %>, <%= listing.country %></span>
            <span><i class="fa-solid fa-bed me-2"></i>Stay details</span>
          </div>
          <div class="price-tag mb-4" style="font-size: 2.4rem;">
            <span class="currency">&#8377;</span><%= listing.price.toLocaleString("en-IN") %>
            <span class="text-soft fs-6 fw-normal">/ night</span>
          </div>

          <div class="detail-owner shell-card mb-4">
            <span class="detail-avatar"><i class="fa-solid fa-user"></i></span>
            <div>
              <div class="text-soft small">Hosted by</div>
              <div class="fw-bold"><%= listing.owner.username %></div>
              <div class="text-soft small">Verified host profile</div>
            </div>
          </div>

          <div class="d-grid gap-2">
            <a href="/listings" class="btn btn-outline-secondary">Back to listings</a>
            <% if (currUser && currUser._id.equals(listing.owner._id)) { %>
              <a href="/listings/<%= listing._id %>/edit" class="btn btn-primary">Edit listing</a>
              <form method="POST" action="/listings/<%= listing._id %>?_method=DELETE" class="m-0">
                <button type="submit" class="btn btn-outline-secondary w-100" onclick="return confirm('Delete this listing?');">Delete listing</button>
              </form>
            <% } %>
          </div>
        </div>
      </aside>
    </div>
  </div>
</section>

<section class="page-section pt-0">
  <div class="container">
    <div class="detail-grid">
      <div class="d-grid gap-4">
        <article class="detail-card fade-up">
          <h2 class="h3 mb-3">About this stay</h2>
          <p class="supporting-copy mb-0"><%= listing.description %></p>
        </article>

        <article class="detail-card fade-up">
          <h2 class="h3 mb-3">Stay details</h2>
          <div class="detail-facts">
            <div class="fact-tile">
              <div class="text-soft small mb-1">Location</div>
              <div class="fw-bold"><%= listing.location %></div>
            </div>
            <div class="fact-tile">
              <div class="text-soft small mb-1">Country</div>
              <div class="fw-bold"><%= listing.country %></div>
            </div>
            <div class="fact-tile">
              <div class="text-soft small mb-1">Price</div>
              <div class="fw-bold">&#8377;<%= listing.price.toLocaleString("en-IN") %> / night</div>
            </div>
            <div class="fact-tile">
              <div class="text-soft small mb-1">Hosting</div>
              <div class="fw-bold">Managed by <%= listing.owner.username %></div>
            </div>
          </div>
        </article>

        <article class="detail-card fade-up">
          <div class="d-flex justify-content-between align-items-center gap-3 mb-3">
            <h2 class="h3 mb-0">Reviews</h2>
            <span class="text-soft"><%= listing.reviews.length %> total</span>
          </div>

          <% if (currUser) { %>
            <div class="panel-card mb-4">
              <h3 class="h5 mb-3">Leave a review</h3>
              <form action="/listings/<%= listing._id %>/reviews" method="POST" class="needs-validation d-grid gap-3" novalidate>
                <div>
                  <label class="form-label" for="comment">Your rating</label>
                  <fieldset class="starability-heartbeat">
                    <input type="radio" id="rate1" name="review[rating]" value="1" required>
                    <label for="rate1" title="Terrible">1 star</label>
                    <input type="radio" id="rate2" name="review[rating]" value="2">
                    <label for="rate2" title="Not good">2 stars</label>
                    <input type="radio" id="rate3" name="review[rating]" value="3">
                    <label for="rate3" title="Average">3 stars</label>
                    <input type="radio" id="rate4" name="review[rating]" value="4">
                    <label for="rate4" title="Very good">4 stars</label>
                    <input type="radio" id="rate5" name="review[rating]" value="5">
                    <label for="rate5" title="Amazing">5 stars</label>
                  </fieldset>
                </div>
                <div>
                  <label for="comment" class="form-label">Your review</label>
                  <textarea name="review[comment]" id="comment" rows="4" class="form-control" placeholder="Share what the stay felt like, what worked well, and what future guests should know." required></textarea>
                  <div class="invalid-feedback">Please add a review comment.</div>
                </div>
                <button type="submit" class="btn btn-primary">Submit review</button>
              </form>
            </div>
          <% } %>

          <% if (listing.reviews.length === 0) { %>
            <div class="empty-state shell-card">
              <div class="empty-state-icon"><i class="fa-solid fa-comment"></i></div>
              <h3 class="h5">No reviews yet</h3>
              <p class="text-soft mb-0">The first review will help set expectations for future guests.</p>
            </div>
          <% } else { %>
            <div class="review-list">
              <% for (let review of listing.reviews) { %>
                <article class="review-card">
                  <div class="review-header mb-2">
                    <div>
                      <div class="fw-bold">@<%= review.author.username %></div>
                      <div class="text-soft small"><%= new Date(review.createdAt).toLocaleDateString('en-IN') %></div>
                    </div>
                    <% if (currUser && currUser._id.equals(review.author._id)) { %>
                      <form method="POST" action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE">
                        <button class="btn btn-sm btn-outline-secondary" type="submit">Remove</button>
                      </form>
                    <% } %>
                  </div>
                  <div class="review-stars mb-2">
                    <% for (let i = 1; i <= 5; i++) { %>
                      <i class="fa-solid fa-star" style="opacity: <%= i <= review.rating ? 1 : 0.25 %>;"></i>
                    <% } %>
                    <span class="ms-2 text-soft"><%= review.rating %>/5</span>
                  </div>
                  <p class="mb-0 text-soft"><%= review.comment %></p>
                </article>
              <% } %>
            </div>
          <% } %>
        </article>
      </div>

      <aside class="d-grid gap-3">
        <div class="detail-card fade-up">
          <h3 class="h5 mb-3">Why this page works better</h3>
          <p class="text-soft mb-0">The core decision info now sits together: image, location, price, host, description, and reviews. That makes the page easier to scan and trust.</p>
        </div>
      </aside>
    </div>
  </div>
</section>
