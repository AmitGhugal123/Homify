<% pageClass = "page-form"; %>
<% pageTitle = "Edit Listing"; %>
<% layout("layouts/boilerplate") %>

<section class="page-hero">
  <div class="container form-shell">
    <div class="page-hero-panel fade-up">
      <div class="section-kicker bg-white text-dark">Update with confidence</div>
      <h1 class="section-title text-white mb-2">Edit your listing without fighting the layout.</h1>
      <p class="mb-0 text-white-50">This version keeps the page calmer and puts the important editing actions first.</p>
    </div>
  </div>
</section>

<section class="page-section pt-0">
  <div class="container form-shell d-grid gap-4">
    <article class="form-card shell-card fade-up">
      <form method="POST" action="/listings/<%= listing._id %>?_method=PUT" enctype="multipart/form-data" class="form-grid needs-validation" novalidate>
        <div>
          <label for="title" class="form-label">Property title</label>
          <input name="listing[title]" id="title" type="text" value="<%= listing.title %>" class="form-control" required>
          <div class="invalid-feedback">Please provide a listing title.</div>
        </div>

        <div>
          <label for="description" class="form-label">Description</label>
          <textarea name="listing[description]" id="description" rows="5" class="form-control" required><%= listing.description %></textarea>
          <div class="invalid-feedback">Please provide a description.</div>
        </div>

        <div class="form-grid-2">
          <div>
            <label for="price" class="form-label">Price per night</label>
            <div class="input-group">
              <span class="input-group-text">&#8377;</span>
              <input name="listing[price]" id="price" type="number" value="<%= listing.price %>" class="form-control" min="0" required>
            </div>
            <div class="invalid-feedback">Please provide a valid price.</div>
          </div>
          <div>
            <label for="image" class="form-label">Replace image</label>
            <input name="image" id="image" type="file" class="form-control" accept="image/*">
          </div>
        </div>

        <div class="form-grid-2">
          <div>
            <label for="location" class="form-label">Location</label>
            <input name="listing[location]" id="location" type="text" value="<%= listing.location %>" class="form-control" required>
            <div class="invalid-feedback">Please provide a location.</div>
          </div>
          <div>
            <label for="country" class="form-label">Country</label>
            <input name="listing[country]" id="country" type="text" value="<%= listing.country %>" class="form-control" required>
            <div class="invalid-feedback">Please provide a country.</div>
          </div>
        </div>

        <div class="d-flex gap-2 flex-wrap pt-2">
          <button type="submit" class="btn btn-primary px-4">Save changes</button>
          <a href="/listings/<%= listing._id %>" class="btn btn-outline-secondary px-4">Cancel</a>
        </div>
      </form>
    </article>

    <article class="detail-card fade-up">
      <h2 class="h5 mb-3">Current image</h2>
      <div class="detail-image-wrap" style="min-height: 280px; height: 280px;">
        <img src="<%= originalImageUrl %>" alt="Current listing image">
      </div>
    </article>
  </div>
</section>
