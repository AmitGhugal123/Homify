<% if (success && success.length) { %>
  <div class="alert alert-success alert-dismissible fade show d-flex align-items-center gap-3 mt-3" role="alert" data-auto-dismiss="5000">
    <i class="fa-solid fa-circle-check"></i>
    <div><strong>Success:</strong> <%= success %></div>
    <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert" aria-label="Close"></button>
  </div>
<% } %>

<% if (error && error.length) { %>
  <div class="alert alert-danger alert-dismissible fade show d-flex align-items-center gap-3 mt-3" role="alert" data-auto-dismiss="6000">
    <i class="fa-solid fa-circle-exclamation"></i>
    <div><strong>Error:</strong> <%= error %></div>
    <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert" aria-label="Close"></button>
  </div>
<% } %>
