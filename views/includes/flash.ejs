<!-- ✅ Success Messages -->
<% if(success && success.length) { %>
    <div class="alert alert-success alert-dismissible fade show d-flex align-items-center" role="alert" style="margin-top: 1rem;">
        <i class="fa-solid fa-circle-check me-2" style="color: #198754; font-size: 1.2rem;"></i>
        <div>
            <strong>Success!</strong> <%= success %>
        </div>
        <button type="button" 
            class="btn-close" 
            data-bs-dismiss="alert" 
            aria-label="Close">
        </button>
    </div>
<% } %>

<!-- ❌ Error Messages -->
<% if(error && error.length) { %>
    <div class="alert alert-danger alert-dismissible fade show d-flex align-items-center" role="alert" style="margin-top: 1rem;">
        <i class="fa-solid fa-circle-exclamation me-2" style="color: #dc3545; font-size: 1.2rem;"></i>
        <div>
            <strong>Error!</strong> <%= error %>
        </div>
        <button type="button" 
            class="btn-close" 
            data-bs-dismiss="alert" 
            aria-label="Close">
        </button>
    </div>
<% } %>

<script>
// Auto-dismiss alerts after 5 seconds
document.addEventListener('DOMContentLoaded', function() {
  const alerts = document.querySelectorAll('.alert');
  alerts.forEach(alert => {
    setTimeout(() => {
      const bsAlert = new bootstrap.Alert(alert);
      bsAlert.close();
    }, 5000);
  });
});
</script>