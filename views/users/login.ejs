<% pageClass = "page-auth"; %>
<% pageTitle = "Log In"; %>
<% layout("/layouts/boilerplate") %>

<section class="page-section auth-wrap">
  <div class="container">
    <div class="auth-layout">
      <aside class="auth-side fade-up">
        <div class="section-kicker bg-white text-dark">Welcome back</div>
        <h1 class="section-title text-white mb-3">Sign in to manage listings and saved stays.</h1>
        <p class="text-white-50 mb-4">The auth flow should feel simple and trustworthy too, so this page now mirrors the calmer design direction of the rest of the product.</p>
        <div class="d-grid gap-3">
          <div class="hero-stat">
            <div class="fw-bold">Faster return flow</div>
            <div class="small text-white-50">Log in and get straight back to your listings.</div>
          </div>
          <div class="hero-stat">
            <div class="fw-bold">Clearer actions</div>
            <div class="small text-white-50">Less decorative clutter around the form.</div>
          </div>
        </div>
      </aside>

      <article class="auth-card shell-card fade-up">
        <h2 class="h3 mb-2">Log in</h2>
        <p class="text-soft mb-4">Access your account to manage stays, reviews, and hosting.</p>

        <form action="/login" method="POST" class="needs-validation" novalidate>
          <div>
            <label for="email" class="form-label">Email</label>
            <input name="email" id="email" type="email" class="form-control" placeholder="you@example.com" required>
            <div class="invalid-feedback">Please enter a valid email.</div>
          </div>

          <div>
            <label for="password" class="form-label">Password</label>
            <div class="input-group">
              <input name="password" id="password" type="password" class="form-control" placeholder="Enter your password" minlength="6" required>
              <button type="button" class="btn btn-outline-secondary" data-password-toggle="password" aria-label="Toggle password visibility">
                <i class="fa-solid fa-eye"></i>
              </button>
            </div>
            <div class="invalid-feedback">Password must be at least 6 characters.</div>
          </div>

          <button type="submit" class="btn btn-primary">Log in</button>
          <p class="mb-0 text-soft">Do not have an account? <a href="/signup" class="fw-bold">Create one</a></p>
        </form>
      </article>
    </div>
  </div>
</section>
