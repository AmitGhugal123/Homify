<% pageClass = "page-auth"; %>
<% pageTitle = "Sign Up"; %>
<% layout("/layouts/boilerplate") %>

<section class="page-section auth-wrap">
  <div class="container">
    <div class="auth-layout">
      <aside class="auth-side fade-up">
        <div class="section-kicker bg-white text-dark">Create your account</div>
        <h1 class="section-title text-white mb-3">Join Homify and start hosting or saving stays with less friction.</h1>
        <p class="text-white-50 mb-4">This signup page keeps the focus on the form and makes the onboarding feel more aligned with the rest of the refreshed UI.</p>
        <div class="d-grid gap-3">
          <div class="hero-stat">
            <div class="fw-bold">Host-ready</div>
            <div class="small text-white-50">Create listings and manage updates from one account.</div>
          </div>
          <div class="hero-stat">
            <div class="fw-bold">Guest-ready</div>
            <div class="small text-white-50">Save favorite properties and come back to them later.</div>
          </div>
        </div>
      </aside>

      <article class="auth-card shell-card fade-up">
        <h2 class="h3 mb-2">Sign up</h2>
        <p class="text-soft mb-4">Create your account to start browsing and hosting with a cleaner workflow.</p>

        <form action="/signup" method="POST" class="needs-validation" novalidate>
          <div>
            <label for="username" class="form-label">Username</label>
            <input name="username" id="username" type="text" class="form-control" placeholder="Choose a username" required>
            <div class="invalid-feedback">Please provide a username.</div>
          </div>

          <div>
            <label for="email" class="form-label">Email</label>
            <input name="email" id="email" type="email" class="form-control" placeholder="you@example.com" required>
            <div class="invalid-feedback">Please enter a valid email.</div>
          </div>

          <div>
            <label for="password" class="form-label">Password</label>
            <div class="input-group">
              <input name="password" id="password" type="password" class="form-control" placeholder="At least 6 characters" minlength="6" required>
              <button type="button" class="btn btn-outline-secondary" data-password-toggle="password" aria-label="Toggle password visibility">
                <i class="fa-solid fa-eye"></i>
              </button>
            </div>
            <div class="invalid-feedback">Password must be at least 6 characters.</div>
          </div>

          <button type="submit" class="btn btn-primary">Create account</button>
          <p class="mb-0 text-soft">Already have an account? <a href="/login" class="fw-bold">Log in</a></p>
        </form>
      </article>
    </div>
  </div>
</section>
