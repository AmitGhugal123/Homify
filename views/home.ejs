<% layout("layouts/boilerplate") %>

<section class="hero-home py-5 py-lg-6">
  <div class="container">
    <div class="row align-items-center g-4">
      <div class="col-lg-7">
        <span class="badge bg-light text-dark mb-3 px-3 py-2">
          <i class="fa-solid fa-house-chimney me-2 text-warning"></i>Welcome to Homify
        </span>
        <h1 class="display-4 fw-bold text-white mb-3">
          Find your next stay with comfort and confidence
        </h1>
        <p class="lead text-white-50 mb-4">
          Explore handpicked listings, transparent pricing, and real reviews from travelers.
          You will be redirected to listings automatically.
        </p>

        <div class="d-flex flex-wrap gap-2 mb-4">
          <a href="/listings" class="btn btn-light btn-lg px-4">
            <i class="fa-solid fa-compass me-2"></i>Explore Listings Now
          </a>
          <% if (!currUser) { %>
            <a href="/signup" class="btn btn-outline-light btn-lg px-4">
              <i class="fa-solid fa-user-plus me-2"></i>Create Account
            </a>
          <% } else { %>
            <a href="/listings/new" class="btn btn-outline-light btn-lg px-4">
              <i class="fa-solid fa-plus me-2"></i>Add New Listing
            </a>
          <% } %>
        </div>

        <div class="text-white-50 small mb-2">Redirecting to listings in <span id="countdown">6</span>s...</div>
        <div class="progress home-progress" role="progressbar" aria-label="Redirect progress" aria-valuemin="0" aria-valuemax="100">
          <div class="progress-bar progress-bar-striped progress-bar-animated" id="redirectBar" style="width: 0%"></div>
        </div>
      </div>

      <div class="col-lg-5">
        <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
          <div class="card-body p-4 p-lg-5">
            <h5 class="fw-bold mb-3">Why users love Homify</h5>
            <ul class="list-unstyled mb-0">
              <li class="mb-3 d-flex align-items-start">
                <i class="fa-solid fa-circle-check text-success me-2 mt-1"></i>
                Verified user reviews and trusted hosts
              </li>
              <li class="mb-3 d-flex align-items-start">
                <i class="fa-solid fa-circle-check text-success me-2 mt-1"></i>
                Fast search experience with clear pricing
              </li>
              <li class="mb-0 d-flex align-items-start">
                <i class="fa-solid fa-circle-check text-success me-2 mt-1"></i>
                Easy listing creation for property owners
              </li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero-home {
    min-height: calc(100vh - 220px);
    display: flex;
    align-items: center;
    background:
      radial-gradient(circle at 20% 20%, rgba(255, 255, 255, 0.16) 0%, rgba(255, 255, 255, 0) 50%),
      linear-gradient(135deg, #1f2937 0%, #334155 40%, #0f766e 100%);
  }

  .home-progress {
    max-width: 420px;
    height: 0.7rem;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.2);
  }

  .home-progress .progress-bar {
    background: linear-gradient(90deg, #f59e0b, #f97316);
  }

  @media (max-width: 768px) {
    .hero-home {
      min-height: auto;
      padding-top: 3rem;
      padding-bottom: 3rem;
    }
  }
</style>

<script>
  (function redirectToListings() {
    var seconds = 6;
    var countdownEl = document.getElementById("countdown");
    var barEl = document.getElementById("redirectBar");
    var total = seconds;

    var timer = setInterval(function () {
      seconds -= 1;
      if (countdownEl) countdownEl.textContent = String(Math.max(seconds, 0));

      var progress = ((total - seconds) / total) * 100;
      if (barEl) barEl.style.width = progress + "%";

      if (seconds <= 0) {
        clearInterval(timer);
        window.location.href = "/listings";
      }
    }, 1000);
  })();
</script>
