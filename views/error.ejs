<% pageClass = "page-form"; %>
<% pageTitle = "Error"; %>
<% layout("/layouts/boilerplate") %>

<section class="page-section auth-wrap">
  <div class="container legal-shell">
    <article class="auth-card shell-card fade-up text-center">
      <div class="section-kicker mx-auto mb-3">
        <i class="fa-solid fa-triangle-exclamation"></i>
        Something went wrong
      </div>
      <div class="display-1 fw-bold text-danger mb-2"><%= err.statusCode || 500 %></div>
      <h1 class="h3 mb-3"><%= err.message || "Something went wrong!" %></h1>
      <p class="text-soft mb-4">
        <% if (err.statusCode === 404) { %>
          The page you tried to reach does not exist, or the link is no longer valid.
        <% } else if (err.statusCode === 403) { %>
          You do not have permission to access this resource.
        <% } else { %>
          An unexpected error occurred. You can head back to browsing and try again from there.
        <% } %>
      </p>

      <div class="d-flex justify-content-center gap-2 flex-wrap mb-4">
        <a href="/listings" class="btn btn-primary">Back to listings</a>
        <a href="/" class="btn btn-outline-secondary">Go home</a>
      </div>

      <% if (process.env.NODE_ENV !== "production") { %>
        <div class="text-start panel-card">
          <div class="fw-bold mb-2">Development details</div>
          <pre class="mb-0 small" style="overflow:auto;"><%= JSON.stringify(err, null, 2) %></pre>
        </div>
      <% } %>
    </article>
  </div>
</section>
