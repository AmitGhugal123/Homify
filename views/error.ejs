<% layout("/layouts/boilerplate") %>

<div class="container d-flex align-items-center justify-content-center" style="min-height: 80vh;">
  <div class="row w-100">
    <div class="col-lg-6 col-md-8 text-center">
      
      <!-- Error Card -->
      <div class="card border-0 shadow-lg" style="border-radius: 15px; overflow: hidden;">
        <div class="card-body p-5">
          
          <!-- Error Icon -->
          <div class="mb-4">
            <i class="fa-solid fa-triangle-exclamation" style="font-size: 4rem; color: #dc3545;"></i>
          </div>

          <!-- Error Code -->
          <div class="mb-3">
            <h1 class="display-1 fw-bold text-danger">
              <%= err.statusCode || 500 %>
            </h1>
          </div>

          <!-- Error Message -->
          <h2 class="h4 fw-bold mb-3">
            <%= err.message || "Something went wrong!" %>
          </h2>

          <!-- Description -->
          <p class="text-muted mb-4">
            <% if (err.statusCode === 404) { %>
              The page you're looking for doesn't exist. It might have been removed or the URL might be incorrect.
            <% } else if (err.statusCode === 403) { %>
              You don't have permission to access this resource.
            <% } else { %>
              An unexpected error occurred. Please try again or contact support if the problem persists.
            <% } %>
          </p>

          <!-- Action Buttons -->
          <div class="d-grid gap-2 mb-3">
            <a href="/listings" class="btn btn-primary btn-lg">
              <i class="fa-solid fa-arrow-left me-2"></i>Back to Listings
            </a>
            <a href="/" class="btn btn-outline-secondary btn-lg">
              <i class="fa-solid fa-home me-2"></i>Go to Home
            </a>
          </div>

          <!-- Support Link -->
          <p class="text-muted small mt-4">
            <i class="fa-solid fa-question-circle me-1"></i>
            Need help? <a href="#" class="text-decoration-none">Contact Support</a>
          </p>

          <!-- Debug Info (only in development) -->
          <% if (process.env.NODE_ENV !== "production") { %>
            <hr class="my-4">
            <div class="text-start">
              <p class="text-muted small mb-2">
                <strong>Error Details (Development Only):</strong>
              </p>
              <pre class="bg-light p-3 rounded text-start small" style="overflow: auto;">
<%= JSON.stringify(err, null, 2) %>
              </pre>
            </div>
          <% } %>

        </div>
      </div>

    </div>
  </div>
</div>
